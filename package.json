{
  "name": "iat",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "uv run uvicorn backend.app.main:app --reload",
    "build": "vite build",
    "setup": "uv run python -m backend.app.cli download-assets",
    "format": "uv run ruff format . && prettier --write .",
    "format:check": "uv run ruff format --check . && prettier --check .",
    "lint": "uv run ruff check --fix . && uv run ty check && tsc --noEmit --project tsconfig.json && eslint . --fix",
    "lint:check": "uv run ruff check . && uv run ty check && tsc --noEmit --project tsconfig.json && eslint .",
    "test": "uv run pytest && vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^5.4.19",
    "vitest": "^3.1.1"
  }
}
